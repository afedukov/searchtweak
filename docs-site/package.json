{
  "name": "searchtweak-docs",
  "private": true,
  "type": "module",
  "scripts": {
    "docs:dev": "vitepress dev docs --host 0.0.0.0 --port 3001",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs --host 0.0.0.0 --port 3001",
    "docs:publish": "npm run docs:build && rm -rf ../public/docs && mkdir -p ../public/docs && cp -R docs/.vitepress/dist/* ../public/docs/"
  },
  "devDependencies": {
    "vitepress": "^1.6.4"
  },
  "dependencies": {
    "markdown-it-mathjax3": "^4.3.2"
  }
}
